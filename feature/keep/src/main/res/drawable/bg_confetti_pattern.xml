<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- White background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:topLeftRadius="@dimen/margin_16"
                android:topRightRadius="@dimen/margin_16"/>
        </shape>
    </item>
    
    <!-- Confetti shapes - scattered across the background -->
    <!-- Pink circle -->
    <item android:left="20dp" android:top="30dp">
        <shape android:shape="oval">
            <solid android:color="#FFB6C1" />
            <size android:width="12dp" android:height="12dp" />
        </shape>
    </item>
    
    <!-- Blue star -->
    <item android:left="80dp" android:top="50dp">
