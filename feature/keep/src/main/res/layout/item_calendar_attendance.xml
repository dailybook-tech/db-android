<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="@dimen/margin_4">

            <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewBold14
                android:id="@+id/tv_date"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:gravity="center" />

            <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewBoldPrimaryColor14
                android:id="@+id/tv_current_date"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:visibility="gone"/>

            <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewRegular14
                android:id="@+id/tv_day"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:gravity="center" />

            <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewRegularPrimaryColor14
                android:id="@+id/tv_current_day"
                android:layout_width="70dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:visibility="gone"/>
        </LinearLayout>

        <View
            android:id="@+id/divider_1"
            android:layout_width="@dimen/margin_1"
            android:layout_height="match_parent"
            android:background="@color/divider_color" />

        <LinearLayout
            android:id="@+id/ll_attendance"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="start|center"
            android:paddingHorizontal="@dimen/margin_10">

            <ImageView
                android:id="@+id/iv_attendance_one"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_2"
                android:visibility="invisible"
                android:src="@drawable/ic_absent_empty"/>

            <ImageView
                android:id="@+id/iv_attendance_two"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_2"
                android:visibility="invisible"
                android:src="@drawable/ic_present_filled"/>

            <ImageView
                android:id="@+id/iv_ot_pill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/margin_2"
                android:visibility="gone"
                android:src="@drawable/ic_ot_pill"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_more"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginHorizontal="@dimen/margin_4"
            android:src="@drawable/ic_more"
            android:padding="@dimen/margin_4" />

        <View
            android:id="@+id/divider_2"
            android:layout_width="@dimen/margin_1"
            android:layout_height="match_parent"
            android:background="@color/divider_color" />

        <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewHintRegular12
            android:id="@+id/tv_add_advance"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:gravity="start|center"
            android:layout_weight="1"
            android:paddingStart="@dimen/margin_12"
            style="@style/textview_bold_12_hyperlink"
            android:textColor="@color/hyperlink_text"
            android:text="@string/add_advance"/>

        <ImageView
            android:id="@+id/iv_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginEnd="@dimen/margin_12"
            android:src="@drawable/ic_chevron_right"/>
    </LinearLayout>

    <View
        android:id="@+id/divider_3"
        android:layout_width="match_parent"
        android:layout_height="@dimen/margin_1"
        android:background="@color/divider_color"/>

</LinearLayout>