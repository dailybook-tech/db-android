<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <ImageView
        android:id="@+id/iv_lock_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_lock"
        android:padding="@dimen/margin_16"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tv_lock_title"
        android:layout_marginTop="@dimen/margin_100"
        android:contentDescription="@string/app_lock" />

    <com.boilerplate.uikit.views.textviews.text20.TextViewBold20
        android:id="@+id/tv_lock_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_lock"
        android:textColor="@color/text_color"
        app:layout_constraintTop_toBottomOf="@+id/iv_lock_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_24" />

    <com.boilerplate.uikit.views.textviews.text14.TextViewRegular14
        android:id="@+id/tv_lock_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/touch_sensor_to_unlock"
        android:textColor="@color/hint_text_color"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@+id/tv_lock_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="@dimen/margin_16"
        android:layout_marginHorizontal="@dimen/margin_24" />

</androidx.constraintlayout.widget.ConstraintLayout>

