<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/item_root">

    <com.boilerplate.uikit.views.textviews.text14.TextViewBold14
        android:id="@+id/tv_initial"
        android:layout_width="@dimen/margin_48"
        android:layout_height="@dimen/margin_48"
        android:background="@drawable/circle_bg"
        android:gravity="center"
        android:layout_marginHorizontal="@dimen/margin_12"
        android:layout_marginTop="@dimen/margin_14"
        android:paddingHorizontal="17dp"
        android:paddingVertical="@dimen/margin_12"
        android:text="A"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/ll_contacts"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="@dimen/margin_12"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintBottom_toBottomOf="@+id/tv_initial"
        app:layout_constraintStart_toEndOf="@+id/tv_initial"
        app:layout_constraintTop_toTopOf="@+id/tv_initial"
        app:layout_constraintEnd_toStartOf="@+id/iv_lock">

        <com.boilerplate.uikit.views.textviews.text14.TextViewBold14
            android:id="@+id/tv_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <com.boilerplate.uikit.views.textviews.text14.TextViewRegular14
            android:id="@+id/tv_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <ImageView
        android:id="@+id/iv_lock"
        android:layout_width="@dimen/margin_24"
        android:layout_height="@dimen/margin_24"
        android:layout_marginEnd="@dimen/margin_16"
        android:src="@drawable/ic_lock"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@+id/ll_contacts"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/ll_contacts"
        app:tint="@color/sub_text_color" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/margin_1"
        android:background="@color/background_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/ll_contacts"
        android:layout_marginTop="@dimen/margin_14"/>
</androidx.constraintlayout.widget.ConstraintLayout>