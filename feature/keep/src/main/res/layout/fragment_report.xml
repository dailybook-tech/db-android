<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary">

    <!-- Toolbar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/report_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:elevation="@dimen/elevation_4"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/icon_size_48"
            android:layout_height="@dimen/icon_size_48"
            android:src="@drawable/ic_arrow_back_small"
            android:padding="@dimen/padding_12"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
            android:id="@+id/tv_report_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/report"
            app:layout_constraintStart_toEndOf="@id/iv_back"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginStart="@dimen/margin_8" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Main content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/report_toolbar"
        app:layout_constraintBottom_toTopOf="@id/ll_action_buttons"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/margin_16">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingVertical="@dimen/padding_20"
            android:background="@color/background_secondary">

            <!-- Report Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_20"
                android:layout_marginTop="@dimen/margin_4"
                app:cardCornerRadius="@dimen/corner_radius_12"
                app:cardElevation="@dimen/elevation_2"
                android:layout_marginHorizontal="@dimen/margin_4"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_20"
                    android:gravity="center">

                    <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
                        android:id="@+id/tv_report_month"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="June 2025 Report"
                        android:textColor="@color/body_text_color"
                        android:layout_gravity="center_horizontal" />

                    <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewRegular12
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/monthly_attendance_payment_report"
                        android:textColor="@color/sub_text_color"
                        android:layout_marginTop="@dimen/margin_4" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Staff Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_20"
                android:layout_marginHorizontal="@dimen/margin_4"
                app:cardCornerRadius="@dimen/corner_radius_12"
                app:cardElevation="@dimen/elevation_2"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_20">

                    <co.dailybook.boilerplate.uikit.views.textviews.text16.TextViewBold16
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/staff_information"
                        android:textColor="@color/body_text_color"
                        android:layout_marginBottom="@dimen/margin_16" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/margin_12">

                        <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewRegular14
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/name_label"
                            android:textColor="@color/sub_text_color" />
                        <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewBold14
                            android:id="@+id/tv_report_name_value"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/body_text_color"
                            android:layout_marginStart="@dimen/margin_8"
                            android:text="Hiralal" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewRegular14
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/phone_label"
                            android:textColor="@color/sub_text_color" />
                        <co.dailybook.boilerplate.uikit.views.textviews.text14.TextViewBold14
                            android:id="@+id/tv_report_phone"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/body_text_color"
                            android:layout_marginStart="@dimen/margin_8"
                            android:text="9483938373" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Attendance Summary Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_20"
                android:layout_marginHorizontal="@dimen/margin_4"
                app:cardCornerRadius="@dimen/corner_radius_12"
                app:cardElevation="@dimen/elevation_2"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_20">

                    <co.dailybook.boilerplate.uikit.views.textviews.text16.TextViewBold16
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/attendance_summary"
                        android:textColor="@color/body_text_color"
                        android:layout_marginBottom="@dimen/margin_16" />

                    <!-- Attendance Table - First Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/margin_12">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rect_border_gray"
                            android:padding="@dimen/padding_16"
                            android:layout_marginEnd="@dimen/margin_6">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewBold12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/present_label"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_4" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text10.TextViewRegular10
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/p"
                                android:textColor="@color/sub_text_color"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_8" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
                                android:id="@+id/tv_present_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="12"
                                android:layout_gravity="center"
                                android:textColor="#4CAF50" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rect_border_gray"
                            android:padding="@dimen/padding_16"
                            android:layout_marginEnd="@dimen/margin_6">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewBold12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/absent_label"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_4" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text10.TextViewRegular10
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/a"
                                android:textColor="@color/sub_text_color"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_8" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
                                android:id="@+id/tv_absent_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4"
                                android:layout_gravity="center"
                                android:textColor="#F44336" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rect_border_gray"
                            android:padding="@dimen/padding_16">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewBold12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/overtime_label"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_4" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text10.TextViewRegular10
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/ot"
                                android:textColor="@color/sub_text_color"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_8" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
                                android:id="@+id/tv_overtime_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="4"
                                android:layout_gravity="center"
                                android:textColor="#FF9800" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Attendance Table - Second Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rect_border_gray"
                            android:padding="@dimen/padding_16"
                            android:layout_marginEnd="@dimen/margin_6">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewBold12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/half_day_label"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_4" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text10.TextViewRegular10
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/_1_2"
                                android:textColor="@color/sub_text_color"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_8" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
                                android:id="@+id/tv_halfday_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="3"
                                android:layout_gravity="center"
                                android:textColor="#9C27B0" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rect_border_gray"
                            android:padding="@dimen/padding_16"
                            android:layout_marginEnd="@dimen/margin_6">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewBold12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/p_plus_half_label"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_4" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text10.TextViewRegular10
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/sub_text_color"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_8" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
                                android:id="@+id/tv_p_plus_half"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:layout_gravity="center"
                                android:textColor="@color/sub_text_color" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:background="@drawable/rect_border_gray"
                            android:padding="@dimen/padding_16">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewBold12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/p_plus_p_label"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_4" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text10.TextViewRegular10
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textColor="@color/sub_text_color"
                                android:layout_gravity="center"
                                android:layout_marginBottom="@dimen/margin_8" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text18.TextViewBold18
                                android:id="@+id/tv_p_plus_p"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:layout_gravity="center"
                                android:textColor="@color/sub_text_color" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Payment Summary Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/margin_20"
                android:layout_marginHorizontal="@dimen/margin_4"
                app:cardCornerRadius="@dimen/corner_radius_12"
                app:cardElevation="@dimen/elevation_2"
                app:cardBackgroundColor="@color/background">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_20">

                    <co.dailybook.boilerplate.uikit.views.textviews.text16.TextViewBold16
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/payment_summary"
                        android:textColor="@color/body_text_color"
                        android:layout_marginBottom="@dimen/margin_16" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/margin_12"
                        android:background="@drawable/rect_border_gray"
                        android:padding="@dimen/padding_16">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewRegular12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/advance_amount_label"
                                android:textColor="@color/sub_text_color" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text16.TextViewBold16
                                android:id="@+id/tv_advance_amount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹10,000"
                                android:textColor="#F44336"
                                android:layout_marginTop="@dimen/margin_4" />
                        </LinearLayout>

                        <View
                            android:layout_width="@dimen/border_width_1"
                            android:layout_height="match_parent"
                            android:background="@color/sub_text_color"
                            android:alpha="0.3" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/margin_16">
                            <co.dailybook.boilerplate.uikit.views.textviews.text12.TextViewRegular12
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/total_earnings_label"
                                android:textColor="@color/sub_text_color" />
                            <co.dailybook.boilerplate.uikit.views.textviews.text16.TextViewBold16
                                android:id="@+id/tv_total_earnings"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="₹5,000"
                                android:textColor="#4CAF50"
                                android:layout_marginTop="@dimen/margin_4" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- Action buttons -->
    <LinearLayout
        android:id="@+id/ll_action_buttons"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_margin="@dimen/margin_16"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_share_pdf"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_56"
            android:text="@string/share_pdf_report"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="@dimen/text_16"
            app:cornerRadius="@dimen/corner_radius_12"
            app:backgroundTint="#3366CC" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/margin_8">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_whatsapp"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_56"
                android:layout_weight="1"
                android:text="@string/share_on_whatsapp"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:textSize="@dimen/text_14"
                app:cornerRadius="@dimen/corner_radius_12"
                app:backgroundTint="#25D366"
                app:icon="@drawable/ic_whatsapp"
                app:iconPadding="@dimen/margin_4"
                app:iconSize="@dimen/icon_size_18" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_export_csv"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height_56"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/margin_8"
                android:text="@string/export_csv"
                android:textColor="@color/color_primary"
                android:textStyle="bold"
                android:textSize="@dimen/text_14"
                app:cornerRadius="@dimen/corner_radius_12"
                app:backgroundTint="@color/background"
                app:strokeColor="@color/color_primary"
                app:strokeWidth="@dimen/border_width_1" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout> 