<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="280dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_review_card"
    android:padding="@dimen/margin_12"
    android:layout_marginEnd="@dimen/margin_12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="@dimen/margin_8">

        <ImageView
            android:id="@+id/iv_review_avatar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:background="@drawable/bg_circle_clip"
            android:clipToOutline="true"
            android:contentDescription="@null"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/margin_8">

            <TextView
                android:id="@+id/tv_review_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_color"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Sai Rawal"/>

            <TextView
                android:id="@+id/tv_review_stars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFB800"
                android:textSize="12sp"
                android:text="★★★★★"/>
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_review_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/sub_text_color"
        android:textSize="12sp"
        android:lineSpacingMultiplier="1.2"
        android:lines="2"
        tools:text="Very nice app, great for attendance marking."/>
</LinearLayout>
