<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:visibility="gone">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="76dp"
        android:background="@color/background_secondary">

        <!-- Sponsored/Ad Label - AdMob Policy Compliant -->
        <TextView
            android:id="@+id/ad_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sponsored"
            android:textSize="@dimen/text_12"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@color/color_primary"
            android:padding="@dimen/margin_4"
            android:elevation="4dp"
            android:layout_marginStart="@dimen/margin_12"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/divider" />

        <!-- Icon -->
        <ImageView
            android:id="@+id/ad_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:contentDescription="Ad icon"
            android:visibility="gone"
            android:layout_marginStart="@dimen/margin_12"
            android:layout_marginTop="@dimen/margin_14"
            android:layout_marginBottom="@dimen/margin_14"
            app:layout_constraintStart_toEndOf="@+id/ad_label"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/divider" />

        <!-- MediaView - compact ad image/video (shown if no icon) -->
        <com.google.android.gms.ads.nativead.MediaView
            android:id="@+id/ad_media"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:contentDescription="Ad media"
            android:visibility="gone"
            android:layout_marginStart="@dimen/margin_12"
            android:layout_marginTop="@dimen/margin_14"
            android:layout_marginBottom="@dimen/margin_14"
            app:layout_constraintStart_toEndOf="@+id/ad_label"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/divider" />

        <!-- Barrier for icon/media -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/ad_image_barrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="end"
            app:constraint_referenced_ids="ad_icon,ad_media" />

        <!-- Text Container -->
        <LinearLayout
            android:id="@+id/ad_text_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_margin="@dimen/margin_12"
            app:layout_constraintStart_toEndOf="@+id/ad_image_barrier"
            app:layout_constraintEnd_toStartOf="@+id/ad_call_to_action"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/divider">

            <!-- Headline -->
            <TextView
                android:id="@+id/ad_headline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/text_color"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"/>

            <!-- Body/Description -->
            <TextView
                android:id="@+id/ad_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textColor="@color/sub_text_color"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- Call to Action Button -->
        <Button
            android:id="@+id/ad_call_to_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/button_enabled_text_color"
            android:backgroundTint="@color/button_enabled_bg_color"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:visibility="gone"
            android:layout_marginEnd="@dimen/margin_12"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/divider" />

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="@dimen/margin_1"
            android:background="@color/background_secondary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.gms.ads.nativead.NativeAdView>
